<div class="fit-shell">
    <div id="dashboardFit" class="fit-content">

        @if (Model != null && Model.detail_data != null && Model.detail_data.Rows.Count > 0)
        {
            <div class="smt-frame w-100 h-100">
                <div class="container-fluid d-flex flex-column h-100 p-2">

                    <!-- INFO BOX -->
                    <div class="row px-2 mb-2 flex-shrink-0">
                        <div class="col d-flex justify-content-between gap-2">
                            <div class="col py-1 border border-2 border-info d-flex flex-column align-items-center rounded smt-info-box">
                                <span class="text-info smt-info-label  text-start ">Line No</span>
                                <span class="text-white smt-info-value" id="line">@Model.line</span>
                            </div>
                            <div class="col py-1 border border-2 border-info d-flex flex-column align-items-center rounded smt-info-box">
                                <span class="text-info smt-info-label  text-start ">Model</span>
                                <span class="text-white smt-info-value">@Model.model</span>
                            </div>
                            <div class="col py-1 border border-2 border-info d-flex flex-column align-items-center rounded smt-info-box">
                                <span class="text-info smt-info-label  text-start">Lot No</span>
                                <span class="text-white  smt-info-value">@Model.lot</span>
                            </div>
                            <div class="col py-1 border border-2 border-info d-flex flex-column align-items-center rounded smt-info-box">
                                <span class="text-info  smt-info-label  text-start">Lot Size</span>
                                <span class="text-white  smt-info-value">@Model.lot_size.ToString("#,##0")</span>
                            </div>
                            <div class="col py-1 border border-2 border-info d-flex flex-column align-items-center rounded smt-info-box">
                                <span class="text-info  smt-info-label  text-start">Balance</span>
                                <span class="text-white  smt-info-value">@Model.balance.ToString("#,##0")</span>
                            </div>
                        </div>
                    </div>

                    <!-- MAIN TABLE -->
                    <div class="row px-2 mb-2 flex-shrink-0">
                        <div class="col-12 w-100">
                            <table class="table table-bordered table-custom-border main-table w-100 text-center">
                                <thead>
                                    <tr>
                                        @foreach (DataColumn column in Model.detail_data.Columns)
                                        {
                                            <th class="py-2">@column.Caption</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (DataRow row in Model.detail_data.Rows)
                                    {
                                        <tr>
                                            @foreach (var item in row.ItemArray)
                                            {
                                                <td class="py-1">
                                                    @if (item is int intValue)
                                                    {
                                                        @intValue.ToString("#,##0")
                                                    }
                                                    else if (item is long longValue)
                                                    {
                                                        @longValue.ToString("#,##0")
                                                    }
                                                    else if (item is decimal decValue)
                                                    {
                                                        @decValue.ToString("#,##0.##")
                                                    }
                                                    else
                                                    {
                                                        @item
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- LOSTTIME + PIE + BAR -->
                   @*  <div class="row px-2 m-0 flex-grow-1" style="min-height:0;"> *@
                        <div class="row px-2 m-0 flex-grow-1 charts-row mt-3">
                        <div class="col-5 d-flex flex-column h-100 pe-3 ps-0">
                            <div class="d-flex justify-content-between align-items-end mb-1 flex-shrink-0">
                                <span class="text-white fw-bold smt-losttime-title">Lostime Analyze (mins):</span>
                                <span class="text-warning fw-bold smt-losttime-total">@Model.lotstimeTotal</span>
                            </div>

                            <div class="w-100 mb-2 flex-shrink-0">
                                <table class="table table-bordered table-custom-border losttime-table">
                                    <thead>
                                        <tr>
                                            @if (Model.detail_data2 != null)
                                            {
                                                @foreach (DataColumn column in Model.detail_data2.Columns)
                                                {
                                                    <th>@column.Caption</th>
                                                }
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.detail_data2 != null)
                                        {
                                            @foreach (DataRow row in Model.detail_data2.Rows)
                                            {
                                                <tr>
                                                    @foreach (var item in row.ItemArray)
                                                    {
                                                        <td>@item</td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="flex-grow-1 position-relative" style="min-height:0;">
                                <div class="chart-wrapper pie-chart-holder">
                                    <canvas id="myPieChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-7 h-100 px-0 d-flex align-items-end">
                            <div class="rounded p-2 smt-bar-panel">
                                <div class="chart-wrapper">
                                    <canvas id="chart_area"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        }
        else
        {
            <div class="smt-frame d-flex justify-content-center align-items-center w-100 h-100">
                <h2 class="text-danger fw-bold">NO DATA</h2>
            </div>
        }
    </div>
</div>