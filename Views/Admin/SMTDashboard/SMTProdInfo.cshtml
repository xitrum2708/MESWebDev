@model DashboardViewModel;
@using System.Text.Json;
@using System.Data;

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section ContentHeader {
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12">
                    <ol class="breadcrumb float-sm-end d-flex justify-content-center align-content-center" style="margin-bottom:0 !important">
                        <li class="breadcrumb-item text-black fw-bold">HOME</li>
                        <li class="breadcrumb-item active fw-bold" aria-current="page">SMT DASHBOARD</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
}
@* <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-3d@1.0.3/dist/chartjs-plugin-3d.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script> *@


<style>
    body, html {
        margin: 0;
        padding: 0;
        height: 100vh;
        height: 100%;
        overflow: hidden !important;
        display: flex;
        flex-direction: column;
    }

    .app-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding-bottom: 5px;

    } 
        .app-content .container-fluid {
            font-family: 'Segoe UI', sans-serif;
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            padding: 5px 15px; /* Giảm padding để tiết kiệm không gian */
        }

        .app-content,
        .app-content .container-fluid,
        ._result,
        .fit-shell,
        #dashboardFit,
        .smt-frame,
        .smt-frame > .container-fluid {
            height: 100%;
            min-height: 0;
        }

            .fit-shell,
            #dashboardFit,
            .smt-frame,
            .smt-frame > .container-fluid {
                display: flex;
                flex-direction: column;
            }

            ._result > * {
                flex: 1 1 auto;
                min-height: 0;
            }
    /* HEADER TEXTS */
    .iqc-shape {
        font-size: calc(1.3rem + 0.3vw); /* Thu nhỏ chữ tiêu đề */
        font-weight: bold;
        letter-spacing: 1px;
        margin: 0;
    }

    #clock {
        font-size: 1.6rem !important; /* Thu nhỏ đồng hồ */
        font-weight: 800;
        margin: 0;
    }

    .app-content .btn.btn-sm {
        font-size: 1.2rem !important; /* Thu nhỏ nút back */
        padding: 6px 15px;
    }

    .breadcrumb-item {
        font-size: 1rem;
    }

    /* VÙNG CHỨA KẾT QUẢ (_result) */
    ._result {
        flex: 1 1 auto; /* Cho phép tự do co giãn */
        display: flex;
        flex-direction: column;
        min-height: 0;
        margin-top: 5px !important;
    }

    /* KHUNG CHỨA TOÀN BỘ NỘI DUNG */
    .smt-frame {
      /*   background-color: #0b1120;
        color: #ffffff; */
        background-color: transparent !important;
        box-shadow: none !important; /* bỏ nếu em vẫn muốn glow */
        border: 2px solid #1e3c72;
        border-radius: 12px;
        padding: 8px;
        box-shadow: 0 0 10px rgba(30, 60, 114, 0.35);
        display: flex;
        flex-direction: column;
        flex: 1 1 auto;
        width: 100%;
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

    .table {
        margin-bottom: 0 !important;
    }

    .table-custom-border th, .table-custom-border td {
        border-color: rgba(255, 255, 255, 0.75) !important;
        vertical-align: middle;
    }

    /* INFO BOXES (Top Row) - Giảm đáng kể kích thước */
    .smt-info-box {
        background: rgba(5, 8, 45, 0.65) !important;
        border-color: #62d9ff !important;
        box-shadow: 0 0 10px rgba(98, 217, 255, 0.45);
        min-height: auto; /* Bỏ min-height cứng */
        padding: 6px 0; /* Thu nhỏ padding dọc */
        justify-content: center;
        border-radius: 6px;
    }

    .smt-info-label {
        color: #9dfcff !important;
        font-size: 1.1rem; /* Giảm chữ nhãn (Line No, Model...) */
        line-height: 1;
        margin-bottom: 2px;
    }

    .smt-info-value {
        color: #ffffff !important;
        font-size: 1.8rem; /* Giảm chữ số/giá trị (TM12, Q990F...) */
        line-height: 1.1;
        text-align: center;
        word-break: break-word;
        font-weight: bold;
    }

    /* MAIN TABLE - Giảm font size và padding */
    .main-table th {
        background-color: #49bdf2 !important;
        color: #ffffff !important;
        font-size: 1.3rem; /* Giảm chữ tiêu đề cột */
        line-height: 1.1;
        padding: 8px 5px !important; /* Giảm padding dọc */
        white-space: nowrap;
    }

    .main-table td {
        background-color: #2b3194 !important;
        color: #ffffff !important;
        font-size: 1.3rem; /* Giảm chữ trong bảng */
        line-height: 1.1;
        padding: 6px 5px !important; /* Giảm padding dọc */
    }

    .main-table tbody tr:nth-child(even) td {
        background-color: #446bea !important;
    }

    .main-table tbody td:first-child {
        text-align: left;
        font-weight: 700;
        min-width: 150px;
        color: #ffffff !important;
        font-weight: 700;
    }

    /* LOSTTIME */
    .smt-losttime-title, .smt-losttime-total {
        font-size: 1.3rem;
        margin-bottom: 4px;
    }

    .losttime-table {
        width: 100%;
        table-layout: fixed;
    }

        .losttime-table th {
            background-color: #49bdf2 !important;
            color: #ffffff !important;
            font-weight: bold;
            text-align: center;
            font-size: 1.1rem;
            padding: 6px 4px !important;
        }

        .losttime-table td {
            background-color: #2b3194 !important;
            color: #ffffff !important;
            padding: 6px 4px !important;
            font-size: 1.1rem;
            line-height: 1.1;
        }

            .losttime-table th:nth-child(1), .losttime-table td:nth-child(1) {
                width: 15%;
                text-align: center;
            }

            .losttime-table th:nth-child(2), .losttime-table td:nth-child(2) {
                width: 55%;
                text-align: left;
                white-space: normal;
            }

            .losttime-table th:nth-child(3), .losttime-table td:nth-child(3) {
                width: 15%;
                text-align: right;
            }

            .losttime-table th:nth-child(4), .losttime-table td:nth-child(4) {
                width: 15%;
                text-align: right;
            }

        .losttime-table tbody tr:nth-child(even) td {
            background-color: #446bea !important;
        }

    /* CHARTS - Ép khu vực biểu đồ bung hết cỡ vào khoảng trống */
    .chart-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .pie-chart-holder {
        flex: 1 1 auto;
        height: 100%; /* Ép chiếm 100% vùng trống */
        min-height: 0;
        display: flex;
        justify-content: center;
        align-items: flex-end !important;
        padding-bottom: 5px;
    }

    .smt-bar-panel {
        background-color: #0f1f3d;
        width: 100%;
        flex: 1 1 auto;
        height: 100%; /* Ép chiếm 100% vùng trống */
        display: flex;
        flex-direction: column;
        border-radius: 8px;
    }

    .chart-wrapper {
        position: relative;
        width: 100%;
        flex: 1; /* Thêm dòng này để lấp đầy smt-bar-panel */
        min-height: 0;
    }

    .charts-row {
        flex: 1 1 auto;
        min-height: 0;
        margin-top: auto;
    }

        .charts-row > [class*="col-"] {
            height: 100%;
            min-height: 0;
        }

    /* Pie chart bám đáy */
    .pie-chart-holder {
        height: 100%;
        min-height: 0;
        display: flex;
        align-items: flex-end !important;
        justify-content: center;
        padding-bottom: 0;
    }

    /* Bar chart bám đáy */
    .smt-bar-panel {
        width: 100%;
        height: 100%;
        min-height: 0;
        display: flex;
        flex-direction: column;
        margin-top: auto;
    }

    /* Đảm bảo khung ngoài của Partial View dùng flex */
    .smt-frame .row.flex-grow-1 {
        min-height: 0; /* Quan trọng để flexbox không bị đẩy tràn */
    }
</style>


<div class="app-content">
    <div class="container-fluid p-0 px-4">
        <div class="row text-center">
            <div class="col-md-3 d-flex justify-content-start align-items-center">
                <a asp-controller="Admin" asp-action="SMTLines" class="btn btn-sm btn-primary">
                    <i class="bi bi-arrow-left-square"></i>
                    Back
                </a>
            </div>
            <div class="col-md-6">
                <div class="iqc-shape">SMT PRODUCTION INFORMATION</div>
            </div>
            <div class="col-md-3 d-flex align-items-center justify-content-center">
                <h4 id="clock"></h4>
            </div>
        </div>

        <div class="row mt-3 _result">
            <partial name="SMTDashboard/_SMTProdInfoResult" model="@Model" />
        </div>
    </div>
</div>

<div id="loadingOverlay"
     class="position-fixed top-0 start-0 w-100 h-100 d-none d-flex align-items-center justify-content-center"
     style="background: rgba(255,255,255,0.7); z-index: 9999;">
    <div class="spinner-border text-success fw-bold" role="status" style="width: 3rem; height: 3rem;">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

@section Scripts {
    <link href="~/css/dashboard.css?@DateTime.Now.Ticks" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <script>
        let barChartInstance = null;
        let pieChartInstance = null;

        $(document).on('change', '.sl_lot', function () {
            const lot = $(this).val();
            reloadPage(lot);
        });

        $(document).ready(function () {
            if (typeof ChartDataLabels !== 'undefined') {
                Chart.register(ChartDataLabels);
            }

            const bar_line = @Html.Raw(Json.Serialize(Model.bar_line_chart));
            const pie_data = @Html.Raw(Json.Serialize(Model.chart_data));

            ShowLineBarChart(bar_line);
            ShowPieChart(pie_data);

            updateClock();
            setInterval(updateClock, 1000);

            setInterval(function () {
                const lot = $('.sl_lot').val();
                reloadPage(lot);
            }, 120000);
        });

        function destroyCharts() {
            if (barChartInstance) {
                barChartInstance.destroy();
                barChartInstance = null;
            }
            if (pieChartInstance) {
                pieChartInstance.destroy();
                pieChartInstance = null;
            }
        }

        function reloadPage(lot) {
            const line = $('#line').text().trim();
            if (!line) return;

            $.ajax({
                url: '@Url.Action("SMTProdInfoSearch", "Admin")',
                type: 'GET',
                data: { line: line, lot: lot },
                success: function (res) {
                    destroyCharts();
                    $('._result').html(res.html);
                    ShowLineBarChart(res.charts.bar_line_chart);
                    ShowPieChart(res.charts.chart_data);
                }
            });
        }

        function updateClock() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hour = String(now.getHours()).padStart(2, '0');
            const minute = String(now.getMinutes()).padStart(2, '0');
            const second = String(now.getSeconds()).padStart(2, '0');

            document.getElementById('clock').textContent =
                `${year}-${month}-${day} ${hour}:${minute}:${second}`;
        }

        function ShowPieChart(pie_data) {
            const canvas = document.getElementById('myPieChart');
            if (!canvas || !pie_data || pie_data.length === 0) return;

            if (pieChartInstance) {
                pieChartInstance.destroy();
                pieChartInstance = null;
            }

            const pie_labels = pie_data.map(item => item.label);
            const pie_values = pie_data.map(item => Number(item.value));

            pieChartInstance = new Chart(canvas.getContext('2d'), {
                type: 'pie',
                data: {
                    labels: pie_labels,
                    datasets: [{
                        data: pie_values,
                        backgroundColor: [
                            '#3ea7d8', '#e77f52', '#2e8c4a', '#d94c4c', '#f1c40f',
                            '#8e44ad', '#16a085', '#ff7f50', '#3498db', '#95a5a6'
                        ],
                        borderColor: '#0b1120',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: 10 },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 16,
                                color: '#fff',
                                font: { size: 25, weight: 'bold' }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            formatter: (value, context) => {
                                const sum = context.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                                return sum ? ((value * 100 / sum).toFixed(0) + '%') : '0%';
                            },
                            font: { size: 25, weight: 'bold' }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const value = Number(context.raw);
                                    const total = context.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                                    const percent = total ? ((value / total) * 100).toFixed(1) : 0;
                                    return `${context.label}: ${value.toLocaleString()} (${percent}%)`;
                                }
                            }
                        }
                    }
                },
                plugins: [ChartDataLabels]
            });
        }

        function ShowLineBarChart(bar_line) {
            const canvas = document.getElementById('chart_area');
            if (!canvas || !bar_line || bar_line.length === 0) return;

            if (barChartInstance) {
                barChartInstance.destroy();
                barChartInstance = null;
            }

            const labels = bar_line.map(item => item.label);
            const target = bar_line.map(item => Number(item.value1));
            const output = bar_line.map(item => Number(item.value2));
            const rate = bar_line.map(item => Number(item.rate));

            const maxTargetOutput = Math.max(...target, ...output, 0);
            const maxRate = Math.max(...rate, 100);

            barChartInstance = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            type: 'line',
                            label: 'Achieve Rate',
                            data: rate,
                            borderColor: '#f1c40f',
                            backgroundColor: '#f1c40f',
                            borderWidth: 3,
                            yAxisID: 'y1',
                            tension: 0.35,
                            pointRadius: 4,
                            datalabels: {
                                color: '#f1c40f',
                                align: 'top',
                                formatter: (v) => `${Number(v).toFixed(1)}%`,
                                font: { size: 18, weight: 'bold' }
                            }
                        },
                        {
                            type: 'bar',
                            label: 'Target',
                            data: target,
                            backgroundColor: '#3b82f6',
                            yAxisID: 'y',
                            // maxBarThickness: 42,
                           categoryPercentage: 0.9,
                             barPercentage: 0.95,
                            datalabels: {
                                color: '#fff',
                                align: 'top',
                                anchor: 'end',
                                font: { size: 18, weight: 'bold' },
                                formatter: (v) => Number(v).toLocaleString()
                            }
                        },
                        {
                            type: 'bar',
                            label: 'Output',
                            data: output,
                            backgroundColor: '#e87c3e',
                            yAxisID: 'y',
                            // maxBarThickness: 42,
                             categoryPercentage: 0.9,
                            barPercentage: 0.95,
                            datalabels: {
                                color: '#fff',
                                align: 'top',
                                anchor: 'end',
                                font: { size: 18, weight: 'bold' },
                                formatter: (v) => Number(v).toLocaleString()
                            }
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: { top: 30 } },
                    scales: {
                        x: {
                            ticks: {
                                color: '#fff',
                                font: { size: 18, weight: 'bold' }
                            },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }
                        },
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            suggestedMax: maxTargetOutput * 1.25,
                            ticks: {
                                color: '#fff',
                                font: { size: 18 },
                                callback: (v) => Number(v).toLocaleString()
                            },
                            grid: { color: 'rgba(255, 255, 255, 0.1)' }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            suggestedMax: Math.max(110, Math.ceil(maxRate / 10) * 10 + 10),
                            grid: { drawOnChartArea: false },
                            ticks: {
                                color: '#f1c40f',
                                font: { size: 18 },
                                callback: (v) => `${v}%`
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            labels: {
                                color: '#fff',
                                font: { size: 18, weight: 'bold' }
                            }
                        }
                    }
                },
                plugins: [ChartDataLabels]
            });
        }
    </script>
}