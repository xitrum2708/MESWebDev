@model MESWebDev.Models.SMT.SMT_DashboardAllLine_Model

@functions {
    // ==================== FUNCTION: GetSmoothColorObj ====================
    // Trả về đối tượng màu để linh hoạt sử dụng cho JS hoặc CSS
    public dynamic GetSmoothColorObj(double percent)
    {
        var colors = new[] {
            new { stop = 0.0,   r = 220, g = 38,  b = 38  }, // Đỏ
            new { stop = 15.0,  r = 239, g = 68,  b = 68  }, // Đỏ nhạt
            new { stop = 25.0,  r = 251, g = 146, b = 60  }, // Cam Pastel
            new { stop = 40.0,  r = 253, g = 224, b = 71  }, // Vàng Pastel
            new { stop = 55.0,  r = 190, g = 242, b = 100 }, // Vàng xanh Pastel
            new { stop = 70.0,  r = 132, g = 204, b = 22  }, // Xanh lá nhạt
            new { stop = 85.0,  r = 34,  g = 197, b = 94  }, // Xanh lá
            new { stop = 100.0, r = 22,  g = 163, b = 74  }  // Xanh lá đậm
        };

        var lower = colors[0];
        var upper = colors[colors.Length - 1];

        for (int i = 0; i < colors.Length - 1; i++)
        {
            if (percent >= colors[i].stop && percent <= colors[i + 1].stop)
            {
                lower = colors[i];
                upper = colors[i + 1];
                break;
            }
        }
        double range = upper.stop - lower.stop;
        double factor = range == 0 ? 0 : (percent - lower.stop) / range;

        int r = (int)Math.Round(lower.r + (upper.r - lower.r) * factor);
        int g = (int)Math.Round(lower.g + (upper.g - lower.g) * factor);
        int b = (int)Math.Round(lower.b + (upper.b - lower.b) * factor);

        return new
        {
            R = r,
            G = g,
            B = b,
            FullRgb = $"rgb({r}, {g}, {b})",
            RgbRaw = $"{r}, {g}, {b}",
            RgbaColor = $"rgba({r}, {g}, {b}, 0.6)"
        };
    }
}

@{
    // ==================== SECTION: ViewData and Layout ====================
    ViewData["Title"] = "SMT Dashboard All Line";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Sử dụng khung Layout

    // ==================== SECTION: JSON Data Preparation ====================
    var hourlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.HourlyOutputs?.Select(x => x.Label).ToList() ?? new List<string>());
    var hourlyDataJson = System.Text.Json.JsonSerializer.Serialize(
        Model.HourlyOutputs?.Select(x => x.Value).ToList() ?? new List<int>());
    var gaugeValue = Model.GaugePercentage;

    var colorStopsJson = System.Text.Json.JsonSerializer.Serialize(new[] {
        new { stop = 0,   r = 220, g = 38,  b = 38  },
        new { stop = 15,  r = 239, g = 68,  b = 68  },
        new { stop = 25,  r = 251, g = 146, b = 60  },
        new { stop = 40,  r = 253, g = 224, b = 71  },
        new { stop = 55,  r = 190, g = 242, b = 100 },
        new { stop = 70,  r = 132, g = 204, b = 22  },
        new { stop = 85,  r = 34,  g = 197, b = 94  },
        new { stop = 100, r = 22,  g = 163, b = 74  }
    });
}

@section ContentHeader {
@*      ==================== SECTION: Content Header ==================== *@
    <div class="app-content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12">
                    <ol class="breadcrumb float-sm-end d-flex justify-content-center align-content-center" style="margin-bottom:0px !important">
                        <li class="breadcrumb-item text-black fw-bold">HOME</li>
                        <li class="breadcrumb-item active fw-bold" aria-current="page">SMT DASHBOARD ALL LINE</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ==================== SECTION: Styles ==================== */
    .dashboard-wrapper {
        background: #0a1428;
        color: #e2e8f0;
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
        padding-bottom: 30px;
    }

    .dashboard-card {
        background: #1e2937;
        border: none;
        border-radius: 12px;
        overflow: hidden;
    }

    .table-dark {
        --bs-table-bg: transparent; /* Fix nền bảng đồng bộ với Card */
    }

        .table-dark th {
            background: #1e4a6e !important;
            color: #94a3b8 !important;
        }

        .table-dark td, .table-dark th {
            border-color: #1e4a6e;
        }

    .table-label {
        color: #99CCFF;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .achievement-gauge {
        position: relative;
        width: 100%;
        max-width: 600px;
        height: 320px;
        margin: 0 auto;
    }

        .achievement-gauge canvas {
            width: 100% !important;
            height: 100% !important;
        }

    .gauge-text {
        position: absolute;
        top: 70%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        width: 100%;
    }

    .status-container {
        display: inline-flex;
        flex-direction: column;
        gap: 10px;
    }

    .status-box {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        border-radius: 8px;
        white-space: nowrap;
        width: 100%;
        font-weight: 500;
    }

        .status-box span:first-child {
            width: 30px;
            font-size: 20px;
            display: flex;
            justify-content: center;
        }

    .status-running {
        border: 2px solid #10b981;
        background: linear-gradient(135deg, #064e3b 0%, #022c22 100%);
    }

    .status-changeover {
        background-color: rgba(255, 215, 0, 0.5);
        border: 2px solid rgba(255, 215, 0, 1);
        transition: 0.3s ease-in-out;
    }

    .status-stop {
        background-color: rgba(255, 0, 0, 0.5);
        border: 2px solid rgba(255, 0, 0, 1);
        transition: 0.3s ease-in-out;
    }

    .quality-bar {
        border-radius: 8px 8px 0 0;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: 10px;
        font-weight: bold;
    }

    #hourlyChartContainer {
        position: relative;
        height: 270px;
        width: 100%;
    }

    .achievement-cell {
        position: relative;
        overflow: hidden;
        color: #ffffff !important;
        font-weight: bold;
        text-align: center;
        background-image: linear-gradient( 90deg, rgba(220, 38, 38, 0.3) 0%, rgba(245, 158, 11, 0.3) 20%, rgba(234, 179, 8, 0.4) 40%, rgba(132, 204, 22, 0.4) 60%, rgba(34, 197, 94, 0.5) 75%, rgba(22, 163, 74, 0.7) 95% );
        background-repeat: no-repeat;
        background-size: 100% 100%;
        padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

        .achievement-cell::after {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: calc(100% - var(--p));
            height: 100%;
            background: rgba(10, 20, 40, 0.85);
            pointer-events: none;
            z-index: 1;
        }

        .achievement-cell .value {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
            color: #ffffff;
            text-shadow: 0 1px 2px rgba(0,0,0,0.35);
        }

    .gauge-separator {
        width: 30%;
        height: 2px;
        background: rgba(255, 255, 255, 0.6);
        margin: 8px auto;
    }

    .gauge-target-label {
        font-size: 1.1rem;
        color: #94a3b8;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>

<div class="dashboard-wrapper">
    <div class="container-fluid py-4" style="max-width: 1550px;">
        <!-- ==================== SECTION: Dashboard Header ==================== -->
        <h1 class="text-center mb-1 text-white fw-bold" style="letter-spacing: 3px;">SMT PRODUCTION DASHBOARD</h1>
        <p class="text-center text-warning mb-4">DAILY PERFORMANCE OVERVIEW</p>

        <!-- ==================== SECTION: Plan vs Actual ==================== -->
        <div class="row g-3 mt-3">
            <div class="col-lg-7">
                <div class="dashboard-card p-3 h-100">
                    <h5 class="table-label border-bottom border-secondary pb-2">PLAN VS ACTUAL</h5>
                    <table class="table table-dark table-sm text-center mb-0">
                        <thead>
                            <tr>
                                <th>LINE NAME</th>
                                <th>PLAN</th>
                                <th>ACTUAL</th>
                                <th>ACHIEVEMENT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PlanActualLines != null && Model.PlanActualLines.Rows.Count > 0)
                            {
                                @foreach (System.Data.DataRow row in Model.PlanActualLines.Rows)
                                {
                                    var achievement = row[3]?.ToString() ?? "0%";
                                    var achievementValue = double.TryParse(achievement.Replace("%", ""), out var val) ? val : 0;
                                    var barPercent = Math.Max(0, Math.Min(100, achievementValue));

                                    <tr style="height: 38px; vertical-align: middle;">
                                        <td>@row[0]</td>
                                        <td>@row[1]</td>
                                        <td>@row[2]</td>
                                        <td class="achievement-cell" style="--p: @(barPercent)%;"><span class="value">@achievement</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ==================== SECTION: Quality Information ==================== -->
            <div class="col-lg-5">
                <div class="dashboard-card p-3 h-100">
                    <h5 class="table-label border-bottom border-secondary pb-2">QUALITY INFORMATION</h5>
                    <table class="table table-dark table-sm text-center mb-4">
                        <thead>
                            <tr>
                                <th class="text-start" style="width: 25%;">TYPE</th>
                                <th style="width: 25%;">OUTPUT</th>
                                <th style="width: 25%;">NG</th>
                                <th style="width: 25%;">ACHIEVEMENT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.QualityInfos != null && Model.QualityInfos.Rows.Count > 0)
                            {
                                @foreach (System.Data.DataRow row in Model.QualityInfos.Rows)
                                {
                                    var achievement = row[3]?.ToString() ?? "0%";
                                    var achievementValue = double.TryParse(achievement.Replace("%", ""), out var val) ? val : 0;
                                    var colorObj = GetSmoothColorObj(achievementValue);

                                    <tr>
                                        <td class="text-start fw-bold">@row[0]</td>
                                        <td>@string.Format("{0:N0}", row[1])</td>
                                        <td>@row[2]</td>
                                        <td class="achievement-cell" style="--p: 100%; --cell-rgb: @colorObj.RgbRaw;">@achievement</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <table class="table table-dark table-sm text-center mb-0">
                        <thead>
                            <tr>
                                <th class="text-start" style="width: 25%;">METRIC</th>
                                <th style="width: 25%;">TODAY</th>
                                <th style="width: 25%;">THIS WEEK</th>
                                <th style="width: 25%;">THIS MONTH</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.QualityOverviews != null && Model.QualityOverviews.Count > 0)
                            {
                                @foreach (var item in Model.QualityOverviews)
                                {
                                    <tr>
                                        <td class="text-start fw-bold">@item.Label</td>
                                        <td>@item.Today</td>
                                        <td>@item.ThisWeek</td>
                                        <td>@item.ThisMonth</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ==================== SECTION: Hourly Output and Quality Overview Charts ==================== -->
        <div class="row g-3 mt-2">
            <div class="col-lg-7">
                <div class="dashboard-card p-3">
                    <h5 class="table-label border-bottom border-secondary pb-2">HOURLY OUTPUT</h5>
                    <div id="hourlyChartContainer">
                        <canvas id="hourlyChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="dashboard-card p-3 h-100">
                    <h5 class="table-label border-bottom border-secondary pb-2">QUALITY OVERVIEW</h5>
                    <div id="qualityChartContainer" style="height: 270px; position: relative;">
                        <canvas id="qualityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== SECTION: Achievement Rate and Downtime ==================== -->
        <div class="row g-3 mt-2">
            <div class="col-lg-7">
                <div class="dashboard-card p-2 h-100">
                    <h5 class="table-label border-bottom border-secondary pb-1">ACHIEVEMENT RATE</h5>
                    <div class="achievement-gauge" style="height: 256px;">
                        <canvas id="achievementGauge"></canvas>
                        <div class="gauge-text">
                            <h1 class="mb-0 text-white fw-bold" id="gaugeValue" style="font-size: 3.2rem;">
                                @Model.GaugePercentage.ToString("F1")<span style="font-size: 1.6rem;">%</span>
                            </h1>
                            <div class="gauge-separator"></div>
                            <div class="gauge-target-label">TARGET: 85% </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="dashboard-card p-2 h-100">
                    <h5 class="table-label border-bottom border-secondary pb-1">DOWNTIME</h5>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-1">
                                <small class="text-muted">TOTAL DOWNTIME</small>
                                <h3 class="text-danger mb-0">@Model.lotstimeTotal <small>min</small></h3>
                            </div>
                            <div class="status-container" style="gap: 6px;">
                                <div class="status-box status-running" style="padding: 8px 16px;">
                                    <span style="font-size:18px;">▶</span>
                                    <span><strong>@Model.linerun</strong> RUNNING</span>
                                </div>
                                <div class="status-box status-changeover text-white" style="padding: 8px 16px;">
                                    <span style="font-size:18px;">🔧</span>
                                    <span><strong>@Model.lotchangeover</strong> CHANGEOVER</span>
                                </div>
                                <div class="status-box status-stop text-white" style="padding: 8px 16px;">
                                    <span style="font-size:18px;">■</span>
                                    <span><strong>@Model.linestop</strong> STOP</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="h-100 d-flex flex-column justify-content-between">
                                <div>
                                    <h6 class="text-warning mb-1">TOP ISSUE</h6>
                                    <table class="table table-dark table-sm mb-0" style="table-layout: fixed;">
                                        <tbody>
                                            @if (Model.Stoplog != null && Model.Stoplog.Rows.Count > 0)
                                            {
                                                @foreach (System.Data.DataRow row in Model.Stoplog.Rows)
                                                {
                                                    <tr style="height: 40px; vertical-align: middle;">
                                                        <td class="fw-bold text-info">
                                                            <i class="bi bi-person-badge me-1"></i> @row["PIC"]
                                                        </td>
                                                        <td class="text-end fw-bold">
                                                            <span class="fs-5 @(Convert.ToDecimal(row["Total_Losttime"]) > 500 ? "text-danger" : "text-warning")">
                                                                @string.Format("{0:N0}", row["Total_Losttime"])
                                                            </span>
                                                            <small class="text-secondary">min</small>
                                                        </td>
                                                    </tr>
                                                }
                                                @for (int i = Model.Stoplog.Rows.Count; i < 3; i++)
                                                {
                                                    <tr style="height: 40px;">
                                                        <td colspan="2" class="text-muted small text-center italic">-</td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="text-end" style="position: relative; top: 25px;">
                                    <div class="text-end">
                                        <img src="~/Image/SMT_REPAIR.png" alt="SMT Repair" width="120" height="120" style="opacity: 0.9;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-3d@1.0.3/dist/chartjs-plugin-3d.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>

    <script>
        // ==================== SHARED COLOR FUNCTION ====================
        const colorStops = @Html.Raw(colorStopsJson);

        function getSmoothColor(percent) {
            let lower = colorStops[0];
            let upper = colorStops[colorStops.length - 1];

            for (let i = 0; i < colorStops.length - 1; i++) {
                if (percent >= colorStops[i].stop && percent <= colorStops[i + 1].stop) {
                    lower = colorStops[i];
                    upper = colorStops[i + 1];
                    break;
                }
            }

            const range = upper.stop - lower.stop;
            const factor = range === 0 ? 0 : (percent - lower.stop) / range;
            const r = Math.round(lower.r + (upper.r - lower.r) * factor);
            const g = Math.round(lower.g + (upper.g - lower.g) * factor);
            const b = Math.round(lower.b + (upper.b - lower.b) * factor);

            return { r, g, b, rgb: `rgb(${r}, ${g}, ${b})` };
        }

        // ==================== CUSTOM 3D BAR PLUGIN ====================
        const bar3DPlugin = {
            id: 'bar3D',
            beforeDatasetsDraw(chart) {
                const { ctx, data, chartArea: { bottom }, scales: { x, y } } = chart;
                const dataset = data.datasets[0];
                const offsetX = 8;
                const offsetY = -8;

                ctx.save();
                dataset.data.forEach((value, index) => {
                    const barX = x.getPixelForValue(index);
                    const barY = y.getPixelForValue(value);
                    const barWidth = chart.getDatasetMeta(0).data[index].width;

                    const baseColor = dataset.backgroundColor[index] || dataset.backgroundColor;
                    const rgbMatch = baseColor.match(/\d+/g);
                    const r = parseInt(rgbMatch[0]);
                    const g = parseInt(rgbMatch[1]);
                    const b = parseInt(rgbMatch[2]);

                    const sideColor = `rgb(${Math.max(0, r - 50)}, ${Math.max(0, g - 50)}, ${Math.max(0, b - 50)})`;
                    const topColor = `rgb(${Math.min(255, r + 30)}, ${Math.min(255, g + 30)}, ${Math.min(255, b + 30)})`;

                    // Vẽ mặt bên phải
                    ctx.beginPath();
                    ctx.moveTo(barX + barWidth / 2, barY);
                    ctx.lineTo(barX + barWidth / 2 + offsetX, barY + offsetY);
                    ctx.lineTo(barX + barWidth / 2 + offsetX, bottom + offsetY);
                    ctx.lineTo(barX + barWidth / 2, bottom);
                    ctx.closePath();
                    ctx.fillStyle = sideColor;
                    ctx.fill();

                    // Vẽ mặt trên
                    ctx.beginPath();
                    ctx.moveTo(barX - barWidth / 2, barY);
                    ctx.lineTo(barX - barWidth / 2 + offsetX, barY + offsetY);
                    ctx.lineTo(barX + barWidth / 2 + offsetX, barY + offsetY);
                    ctx.lineTo(barX + barWidth / 2, barY);
                    ctx.closePath();
                    ctx.fillStyle = topColor;
                    ctx.fill();
                });
                ctx.restore();
            }
        };
        Chart.register(bar3DPlugin);

        // ==================== HOURLY OUTPUT CHART ====================
        const hourlyLabels = @Html.Raw(hourlyLabelsJson);
        const hourlyData = @Html.Raw(hourlyDataJson);
        const hourlyAchievePercents = @Html.Raw(Json.Serialize(Model.HourlyOutputs?.Select(x => x.AchievePercent) ?? new List<decimal>()));

        const maxValue = hourlyData.length ? Math.max(...hourlyData) : 100;
        const yAxisMax = Math.ceil(maxValue / 50) * 70 + 100;

        const barColors1 = hourlyAchievePercents.map(percent => {
            const normalizedPercent = Math.min(100, percent);
            return getSmoothColor(normalizedPercent).rgb;
        });

        const hourlyCtx = document.getElementById('hourlyChart').getContext('2d');
        new Chart(hourlyCtx, {
            type: 'bar',
            data: {
                labels: hourlyLabels,
                datasets: [{
                    label: 'Output',
                    data: hourlyData,
                    backgroundColor: barColors1,
                    borderRadius: 0,
                    barThickness: 30,
                    maxBarThickness: 45
                }]
            },
            options: {
                animations: false,
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: { top: 20, right: 20 } },
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        display: true, color: '#ffffff', anchor: 'end', align: 'top', offset: 12,
                        font: { weight: 'bold', size: 14 }, formatter: value => value
                    }
                },
                scales: {
                    y: { beginAtZero: true, max: yAxisMax, grid: { color: '#334155' }, ticks: { color: '#94a3b8', font: { size: 14 }, stepSize: 50 } },
                    x: { grid: { color: '#334155' }, ticks: {  color: '#94a3b8', font: { size: 14 }  , maxRotation: 0, minRotation: 0 } }
                }
            },
            plugins: [ChartDataLabels]
        });

        // ==================== ACHIEVEMENT GAUGE CHART ====================
        const gaugePercentage = @gaugeValue;
        const gaugeCanvas = document.getElementById('achievementGauge');
        const ctxGauge = gaugeCanvas.getContext('2d');

        const dpr = window.devicePixelRatio || 1;
        const rect = gaugeCanvas.getBoundingClientRect();
        gaugeCanvas.width = rect.width * dpr;
        gaugeCanvas.height = rect.height * dpr;
        ctxGauge.scale(dpr, dpr);

        const centerX = rect.width / 2;
        const centerY = rect.height * 0.85;
        const radius = Math.min(rect.width, rect.height) * 0.7;
        const lineWidthGauge = radius * 0.35;
        const startAngle = Math.PI;
        const endAngle = 2 * Math.PI;
        const angleRange = endAngle - startAngle;
        const filledAngle = startAngle + (angleRange * gaugePercentage / 100);

        function drawRainbowArc(startAngle, endAngle, percent) {
            const steps = 360;
            for (let i = 0; i < steps; i++) {
                const a1 = startAngle + (angleRange * i / steps);
                const a2 = startAngle + (angleRange * (i + 1) / steps);
                if (a1 > filledAngle) break;
                ctxGauge.beginPath();
                ctxGauge.arc(centerX, centerY, radius, a1, Math.min(a2, filledAngle) + 0.01);
                ctxGauge.strokeStyle = getSmoothColor((i / steps) * 100).rgb;
                ctxGauge.lineWidth = lineWidthGauge;
                ctxGauge.stroke();
            }
        }

        drawRainbowArc(startAngle, endAngle, gaugePercentage);
        ctxGauge.beginPath();
        ctxGauge.arc(centerX, centerY, radius, filledAngle, endAngle);
        ctxGauge.strokeStyle = '#334155';
        ctxGauge.lineWidth = lineWidthGauge;
        ctxGauge.stroke();

        // ==================== QUALITY OVERVIEW 3D CHART ====================
        @{
                var qualityFirstItem = Model.QualityOverviews?.FirstOrDefault();
                var qTodayVal = 0.0; var qWeekVal = 0.0; var qMonthVal = 0.0;
                if (qualityFirstItem != null)
                {
                        double.TryParse(qualityFirstItem.Today?.Replace("%", ""), out qTodayVal);
                        double.TryParse(qualityFirstItem.ThisWeek?.Replace("%", "").Replace(" min", ""), out qWeekVal);
                        double.TryParse(qualityFirstItem.ThisMonth?.Replace("%", "").Replace(" min", ""), out qMonthVal);
                }
                var qualityLabelsJson = System.Text.Json.JsonSerializer.Serialize(new[] { "TODAY", "THIS WEEK", "THIS MONTH" });
                var qualityDataJson = System.Text.Json.JsonSerializer.Serialize(new[] { qTodayVal, qWeekVal > 100 ? 99.9 : qWeekVal, qMonthVal > 100 ? 99.9 : qMonthVal });
        }

        const qualityLabels = @Html.Raw(qualityLabelsJson);
        const qualityData = @Html.Raw(qualityDataJson);
        const qualityColors = ['rgb(18, 97, 166)', 'rgb(18, 97, 166)', 'rgb(18, 97, 166)'];

        const qualityCtx = document.getElementById('qualityChart').getContext('2d');
        new Chart(qualityCtx, {
            type: 'bar',
            data: {
                labels: qualityLabels,
                datasets: [{
                    label: 'Quality %',
                    data: qualityData,
                    backgroundColor: qualityColors,
                    borderRadius: 0,
                    barThickness: 70,
                    maxBarThickness: 80
                }]
            },
            options: {
                animations: false,
                responsive: true,
                maintainAspectRatio: false,
                layout: { padding: { top: 25, right: 30 } },
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        display: true, color: '#ffffff', anchor: 'end', align: 'top', offset: 20,
                        font: { weight: 'bold', size: 15 }, formatter: value => value.toFixed(1) + '%'
                    }
                },
                scales: {
                    y: { beginAtZero: false, min: 0, max: 120, grid: { color: '#334155' }, ticks: { color: '#94a3b8', font: { size: 14, weight: 'bold' }, stepSize: 10, callback: value => value + '%' } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 13, weight: 'bold' } } }
                }
            },
            plugins: [ChartDataLabels, {
                id: 'quality3D',
                beforeDatasetsDraw(chart) {
                    const { ctx, chartArea: { bottom }, scales: { x, y } } = chart;
                    const dataset = chart.data.datasets[0];
                    const offsetX = 18; const offsetY = -18;
                    ctx.save();
                    dataset.data.forEach((value, index) => {
                        const barX = x.getPixelForValue(index); const barY = y.getPixelForValue(value);
                        const barWidth = chart.getDatasetMeta(0).data[index].width;
                        const baseColor = dataset.backgroundColor[index];
                        const rgbMatch = baseColor.match(/\d+/g);
                        const r = rgbMatch ? parseInt(rgbMatch[0]) : 100;
                        const g = rgbMatch ? parseInt(rgbMatch[1]) : 100;
                        const b = rgbMatch ? parseInt(rgbMatch[2]) : 200;

                        const sideColor = `rgb(${Math.max(0, r - 50)}, ${Math.max(0, g - 50)}, ${Math.max(0, b - 50)})`;
                        const topColor = `rgb(${Math.min(255, r + 30)}, ${Math.min(255, g + 30)}, ${Math.min(255, b + 30)})`;

                        ctx.beginPath(); ctx.moveTo(barX + barWidth / 2, barY); ctx.lineTo(barX + barWidth / 2 + offsetX, barY + offsetY); ctx.lineTo(barX + barWidth / 2 + offsetX, bottom + offsetY); ctx.lineTo(barX + barWidth / 2, bottom); ctx.closePath(); ctx.fillStyle = sideColor; ctx.fill();
                        ctx.beginPath(); ctx.moveTo(barX - barWidth / 2, barY); ctx.lineTo(barX - barWidth / 2 + offsetX, barY + offsetY); ctx.lineTo(barX + barWidth / 2 + offsetX, barY + offsetY); ctx.lineTo(barX + barWidth / 2, barY); ctx.closePath(); ctx.fillStyle = topColor; ctx.fill();
                    });
                    ctx.restore();
                }
            }]
        });
    </script>
}