            3. Calculate base on line/date/working hour
        */ *@

@section Scripts {
    <link href="~/css/prodplan.css?@DateTime.Now.Ticks" rel="stylesheet" />
    <script src="~/js/index.global.min.js"></script>
    <script src="~/js/loadingpage.js?@DateTime.Now.Ticks"></script>
    <script src="~/js/pp_holidayCalendar.js?@DateTime.Now.Ticks"></script>
    <script src="~/js/pp_prodPlanSchedule.js?@DateTime.Now.Ticks"></script>
    <script src="~/js/pp_workingCalendar.js?@DateTime.Now.Ticks"></script>

@*     <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler/index.global.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler/index.global.min.js"></script>
    @using System.Text.Json *@

<script>
    document.addEventListener('DOMContentLoaded', function () {
      const calendarEl = document.getElementById('calendar');

      const calendar = new FullCalendar.Calendar(calendarEl, {
        schedulerLicenseKey: 'CC-Attribution-NonCommercial-NoDerivatives', // trial key [5](https://fullcalendar.io/docs/premium)

        initialView: 'resourceTimelineDay',
        height: 'auto',
        nowIndicator: true,
        resourceAreaWidth: 160,
        resourceAreaHeaderContent: 'Line',

        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'resourceTimelineDay,resourceTimelineWeek,resourceTimelineMonth,resourceTimelineYear'
        },
        views: {
          resourceTimelineDay:   { buttonText: 'Day' },
          resourceTimelineWeek:  { buttonText: 'Week' },
          resourceTimelineMonth: { buttonText: 'Month' },
          resourceTimelineYear:  { buttonText: 'Year' }
        },

        editable: true,
        eventDurationEditable: true,
        eventStartEditable: true,
        eventResourceEditable: true, // cho phép kéo sang line khác [1](https://fullcalendar.io/docs/timeline-view)

        // fetch resources
        resources: async (fetchInfo, success, fail) => {
          try {
            const res = await fetch(`/preview?start=${fetchInfo.startStr}&end=${fetchInfo.endStr}`);
            const data = await res.json();
            success(data.resources);
          } catch (e) { fail(e); }
        },

        // fetch events + backgroundEvents
        events: async (fetchInfo, success, fail) => {
          try {
            const res = await fetch(`/preview?start=${fetchInfo.startStr}&end=${fetchInfo.endStr}`);
            const data = await res.json();
            success([...(data.events || []), ...(data.backgroundEvents || [])]);
          } catch (e) { fail(e); }
        },

        // Tooltip hover
        eventDidMount: function(info) {
          // ignore background breaks
          if (info.event.display === 'background') return;

          const ep = info.event.extendedProps || {};
          const line = info.event.getResources?.()?.[0]?.id || info.event._def.resourceIds?.[0] || '';

          const tip = `${ep.Lotno} | ${ep.PCBKey} | RO${ep.RunOrder} | Qty ${ep.Qty}\nLine: ${line}\n${info.event.start?.toLocaleString()} - ${info.event.end?.toLocaleString()}`;

          new bootstrap.Tooltip(info.el, {
            title: tip.replaceAll('\n','<br/>'),
            html: true,
            placement: 'top',
            trigger: 'hover',
            container: 'body'
          });
        },

        // Drag/drop validate
        eventDrop: async function(info) { await validateLot(info); },  
        eventResize: async function(info) { await validateLot(info); }  
      });

      calendar.render();

      document.getElementById('btnRefresh').addEventListener('click', () => calendar.refetchEvents());

      async function validateLot(info) {
        // ignore background events
        if (info.event.display === 'background') return;

        const ep = info.event.extendedProps || {};
        const lotno = ep.Lotno;

        // collect current events for that lotno
        const lotEvents = calendar.getEvents()
          .filter(e => e.display !== 'background')
          .filter(e => (e.extendedProps?.Lotno || '') === lotno)
          .map(e => ({
            id: e.id,
            lotno: e.extendedProps?.Lotno,
            pcbKey: e.extendedProps?.PCBKey,
            runOrder: e.extendedProps?.RunOrder,
            qty: e.extendedProps?.Qty,
            lineCode: e.getResources?.()?.[0]?.id || e._def.resourceIds?.[0],
            start: e.start?.toISOString(),
            end: e.end?.toISOString()
          }));

        const res = await fetch('/validate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lotno, events: lotEvents })
        });

        const data = await res.json();
        if (!data.ok) {
          info.revert(); // rollback drag/resize 
          alert(data.message || "Vi phạm điều kiện CumQty(RO1) >= CumQty(RO2)");
        }
      }
    });
</script>
}