@using MESWebDev.Common
@using MESWebDev.Models.IQC.VM
@using MESWebDev.Models.ProdPlan
@using MESWebDev.Models.ProdPlan.PC
@using MESWebDev.Services
@inject ITranslationService TranslationService
@using System.Globalization
@model ProdPlanViewModel

@{
    var languageCode = Context.Session.GetString("LanguageCode") ?? "vi";
    ViewData["Title"] = TranslationService.GetTranslation("MenuManagement", languageCode);
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section ContentHeader {
    @await Html.PartialAsync("_Breadcrumb", ViewBag.Breadcrumbs as List<MESWebDev.DTO.BreadcrumbItemDto>)
}
@try
{

    <div class="app-content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="float-start d-flex justify-content-center align-items-center">
                                <h3 class="card-title fw-bold fs-6">
                                    @* Production Plan *@
                                    @if (Model.start_sch_dt != null)
                                    {
                                        <span class="lastRun badge bg-success fs-6 p-2">
                                            Last run: @Convert.ToDateTime(Model.start_sch_dt).ToString("yyyy-MM-dd HH:mm:ss")
                                        </span>
                                    }
                                </h3>
   
                            </div>
                            <div class="float-end d-flex justify-content-center align-items-center">

                                <a class="btn btn-info btn-sm bt_loadPlan me-2">
                                    <i class="bi bi-gear"></i>
                                    @TranslationService.Trans("StartSchedule")</a>

                                <a class="btn btn-success btn-sm bt_reload me-2">
                                    <i class="bi bi-arrow-clockwise"></i>
                                    @TranslationService.Trans("Reload")
                                </a>
                                @* <a class="btn btn-secondary btn-sm bt_master me-2">Master</a> *@
                                <a class="btn btn-primary btn-sm bt_save me-2">
                                    <i class="bi bi-floppy"></i>
                                    @TranslationService.Trans("Save")
                                </a>
                                <a asp-action="DownloadSMTProdPlan" asp-controller="ProdPlan" class="btn btn-secondary btn-sm me-2">
                                    <i class="bi bi-download"></i>
                                    @TranslationService.Trans("Download")
                                </a>
                              
                            </div>
                        </div>
                        <div class="card-body" >
                            @* <h2>Product Schedule (Resource Timeline View)</h2> *@

                            <div class="enterprise-container">

                                <!-- LEFT PANEL -->
                                <div class="panel panel-left" id="schedulePanel">
                                    <div class="panel-header">
                                        <span>Production Schedule</span>
                                        <div class="btn-group ms-2 rounded-2" role="group">
                                            <button id="zoomIn" class="btn btn-sm btn-outline-success fw-bold">
                                                <i class="bi bi-zoom-in fw-bold"></i>
                                            </button>
                                            <button id="zoomOut" class="btn btn-sm btn-outline-success fw-bold">
                                                <i class="bi bi-zoom-out fw-bold"></i>
                                            </button>
                                        </div>
                                        <div class="panel-actions">
                                            <button class="btn-full fw-bold" data-target="schedulePanel" title="Fullsceen">
                                                <i class="bi bi-fullscreen"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="panel-body">
                                        <partial name="SMT/FullCalendar/_FullCalendar" />
                                    </div>
                                </div>

                                <!-- DIVIDER -->
                                <div class="divider"></div>

                                <!-- RIGHT PANEL -->
                                <div class="panel panel-right" id="utilPanel">
                                    <div class="panel-header">
                                        <span>Line Utilization</span>
                                        <div class="panel-actions">
                                            <button class="btn-full fw-bold" data-target="utilPanel" title="Fullscreen">
                                                <i class="bi bi-fullscreen"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="panel-body">
                                        @* <div id="lineUtilization"> *@
                                            <partial name="SMT/FullCalendar/_LineUtilization" />
                                        @* </div> *@
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <Partial name="PC/_Upload" />
    <Partial name="_LoadingPartial" />
}
catch(Exception ex)
{
    string t = ex.Message;
}
